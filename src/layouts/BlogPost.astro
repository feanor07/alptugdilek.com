---
import Base from './Base.astro';

interface Props {
  title: string;
  date: string;
  description?: string;
}

const { title, date, description } = Astro.props.frontmatter || Astro.props;
---

<Base title={`${title} — Alptug Dilek`} description={description}>
  <article>
    <header>
      <h1>{title}</h1>
      <time datetime={date}>{new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer>
      <a href="/blog">&larr; Back to blog</a>
    </footer>
  </article>
</Base>

<style>
  header {
    margin-bottom: 2rem;
  }

  header h1 {
    margin-bottom: 0.25rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .prose {
    margin-bottom: 2rem;
  }

  .prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1rem;
  }

  footer a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
